        if enterPressed then
            confirm()
        end
    end)
    
    return function()
        return result
    end
end

-- FLY FUNCTION
local function enableFly(speed)
    if flying then
        -- Disable fly
        if bodyVelocity then bodyVelocity:Destroy() end
        if bodyGyro then bodyGyro:Destroy() end
        flying = false
        activeStates.fly = false
        if humanoid then
            humanoid.PlatformStand = false
        end
        showNotification("🛑 Fly Mode: OFF", Color3.fromRGB(200, 50, 50))
    else
        -- Enable fly
        if not character or not rootPart then return end
        
        flying = true
        activeStates.fly = true
        activeStates.flySpeed = speed or 50
        
        bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(1, 1, 1) * 100000
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = rootPart
        
        bodyGyro = Instance.new("BodyGyro")
        bodyGyro.MaxTorque = Vector3.new(1, 1, 1) * 100000
        bodyGyro.CFrame = rootPart.CFrame
        bodyGyro.Parent = rootPart
        
        if humanoid then
            humanoid.PlatformStand = true
        end
        
        showNotification(string.format("✈️ Fly Mode: ON (Speed: %s)", tostring(speed)), Color3.fromRGB(0, 200, 100))
        
        -- Fly movement loop
        coroutine.wrap(function()
            while flying and bodyVelocity and bodyGyro do
                local moveVector = Vector3.new()
                local currentSpeed = activeStates.flySpeed
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                    moveVector = moveVector + (workspace.CurrentCamera.CFrame.LookVector * Vector3.new(1, 0, 1))
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                    moveVector = moveVector - (workspace.CurrentCamera.CFrame.LookVector * Vector3.new(1, 0, 1))
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                    moveVector = moveVector - (workspace.CurrentCamera.CFrame.RightVector * Vector3.new(1, 0, 1))
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                    moveVector = moveVector + (workspace.CurrentCamera.CFrame.RightVector * Vector3.new(1, 0, 1))
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                    moveVector = moveVector + Vector3.new(0, 1, 0)
                end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                    moveVector = moveVector - Vector3.new(0, 1, 0)
                end
                
                if moveVector.Magnitude > 0 then
                    moveVector = moveVector.Unit * currentSpeed
                end
                
                if bodyVelocity then
                    bodyVelocity.Velocity = moveVector
                end
                if bodyGyro then
                    bodyGyro.CFrame = workspace.CurrentCamera.CFrame
                end
                
                RunService.Heartbeat:Wait()
            end
        end)()
    end
end

-- INVISIBLE FUNCTION
local function setInvisible(state)
    activeStates.invisible = state
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = state and 1 or 0
        elseif part:IsA("Decal") then
            part.Transparency = state and 1 or 0
        end
    end
    
    if state then
        showNotification("👻 Invisible: ON", Color3.fromRGB(150, 100, 255))
    else
        showNotification("👤 Invisible: OFF", Color3.fromRGB(100, 150, 255))
    end
end

-- GODMODE FUNCTION
local function enableGodmode()
    if not activeStates.godmode then
        activeStates.godmode = true
        
        local function onDied()
            if activeStates.godmode then
                humanoid.Health = humanoid.MaxHealth
            end
        end
        
        local function onHealthChanged(health)
            if activeStates.godmode and health <= 0 then
                humanoid.Health = humanoid.MaxHealth
            end
        end
        
        humanoid.BreakJointsOnDeath = false
        humanoid:GetPropertyChangedSignal("Health"):Connect(onHealthChanged)
        humanoid.Died:Connect(onDied)
        
        showNotification("🛡️ Godmode: ACTIVATED (Immortal)", Color3.fromRGB(255, 200, 50))
    else
        activeStates.godmode = false
        humanoid.BreakJointsOnDeath = true
        showNotification("⚠️ Godmode: DEACTIVATED", Color3.fromRGB(255, 100, 50))
    end
end

