-- ==================== ESP SYSTEM (replaces BAN) ====================
local espEnabled = false
local espObjects = {}
local espConnections = {}

local function getESPColor(targetPlayer)
    if targetPlayer.Team and player.Team and targetPlayer.Team == player.Team then
        return Color3.fromRGB(0, 255, 100)
    end
    return Color3.fromRGB(255, 50, 50)
end

local function updateDistanceLabel(targetPlayer, label)
    if not espEnabled or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return
    end
    local dist = (rootPart.Position - targetPlayer.Character.HumanoidRootPart.Position).Magnitude
    label.Text = string.format("%.0f studs", dist)
end

local function createESP(targetPlayer)
    if not targetPlayer.Character or targetPlayer == player then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = targetPlayer.Character
    highlight.FillTransparency = 0.5
    highlight.OutlineTransparency = 0.2
    highlight.FillColor = getESPColor(targetPlayer)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.Parent = targetPlayer.Character
    
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_NameTag"
    billboard.Size = UDim2.new(0, 220, 0, 50)
    billboard.Adornee = targetPlayer.Character:FindFirstChild("Head") or targetPlayer.Character:FindFirstChild("HumanoidRootPart")
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = targetPlayer.Character
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.6, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlayer.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextStrokeTransparency = 0.3
    nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 14
    nameLabel.Parent = billboard
    
    local distLabel = Instance.new("TextLabel")
    distLabel.Size = UDim2.new(1, 0, 0.4, 0)
    distLabel.Position = UDim2.new(0, 0, 0.6, 0)
    distLabel.BackgroundTransparency = 1
    distLabel.Text = ""
    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    distLabel.Font = Enum.Font.Gotham
    distLabel.TextSize = 10
    distLabel.Parent = billboard
    
    espObjects[targetPlayer] = {highlight = highlight, billboard = billboard}
    
    local conn = RunService.Heartbeat:Connect(function()
        if espEnabled and espObjects[targetPlayer] and targetPlayer.Character then
            updateDistanceLabel(targetPlayer, distLabel)
        end
    end)
    table.insert(espConnections, conn)
end

local function removeESP(targetPlayer)
    local data = espObjects[targetPlayer]
    if data then
        if data.highlight then data.highlight:Destroy() end
        if data.billboard then data.billboard:Destroy() end
        espObjects[targetPlayer] = nil
    end
end

local function clearAllESP()
    for plr, _ in pairs(espObjects) do
        removeESP(plr)
    end
    for _, conn in ipairs(espConnections) do
        conn:Disconnect()
    end
    espConnections = {}
end

local function toggleESP()
    espEnabled = not espEnabled
    
    if espEnabled then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player then createESP(plr) end
        end
        
        local addedConn = Players.PlayerAdded:Connect(function(plr)
            if espEnabled and plr ~= player then createESP(plr) end
        end)
        local removedConn = Players.PlayerRemoving:Connect(removeESP)
        table.insert(espConnections, addedConn)
        table.insert(espConnections, removedConn)
        
        showNotification("👁️ ESP ENABLED - Players highlighted", Color3.fromRGB(0, 200, 255))
    else
        clearAllESP()
        showNotification("👁️ ESP DISABLED", Color3.fromRGB(200, 80, 80))
    end
end

-- ==================== SPECTATE SYSTEM (replaces MESSAGE) ====================
local spectating = false
local currentTarget = nil
local camera = workspace.CurrentCamera
local spectateConnection = nil

local function stopSpectate()
    if spectating then
        spectating = false
        camera.CameraSubject = character:FindFirstChild("Humanoid")
        camera.CameraType = Enum.CameraType.Custom
        
        if currentTarget and currentTarget.Character then
            local glow = currentTarget.Character:FindFirstChild("SpectateGlow")
            if glow then glow:Destroy() end
        end
        
        currentTarget = nil
        if spectateConnection then spectateConnection:Disconnect() end
        spectateConnection = nil
        
        showNotification("🔴 Stopped spectating", Color3.fromRGB(255, 100, 100))
    end
end

local function startSpectate(targetPlayer)
    if targetPlayer == player then
        showNotification("❌ Cannot spectate yourself", Color3.fromRGB(255, 80, 80))
        return
    end
    
    if not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
        showNotification("⚠️ Player has no character", Color3.fromRGB(255, 180, 50))
        return
    end
    
    stopSpectate()
    spectating = true
    currentTarget = targetPlayer
    
    local glow = Instance.new("Highlight")
    glow.Name = "SpectateGlow"
    glow.Adornee = targetPlayer.Character
    glow.FillColor = Color3.fromRGB(255, 200, 0)
    glow.OutlineColor = Color3.fromRGB(255, 100, 0)
    glow.FillTransparency = 0.4
    glow.Parent = targetPlayer.Character
    
    camera.CameraSubject = targetPlayer.Character:FindFirstChild("Humanoid")
    camera.CameraType = Enum.CameraType.Attach
    
    showNotification(string.format("🎥 Spectating: %s", targetPlayer.Name), Color3.fromRGB(100, 200, 255))
    
    spectateConnection = RunService.Heartbeat:Connect(function()
        if not spectating or not currentTarget then
            stopSpectate()
            return
        end
        if not currentTarget.Parent or not currentTarget.Character or not currentTarget.Character:FindFirstChild("HumanoidRootPart") then
            showNotification("Target left or died", Color3.fromRGB(255, 150, 50))
            stopSpectate()
        end
    end)
end

-- ==================== FLY SYSTEM ====================
local flying = false
local bodyVelocity = nil
local bodyGyro = nil
local flyConnection = nil
local verticalVelocity = nil
local moveDirection = Vector3.new()

local function startFly(speed)
    if not character or not rootPart then return end
    
    flying = true
    activeStates.fly = true
    activeStates.flySpeed = speed or 50
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1, 0, 1) * 100000
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
    
    verticalVelocity = Instance.new("BodyVelocity")
    verticalVelocity.MaxForce = Vector3.new(0, 100000, 0)
    verticalVelocity.Velocity = Vector3.new(0, 0, 0)
    verticalVelocity.Parent = rootPart
    
    if humanoid then
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
    end
    
    local function updateMovement()
        if not flying or not bodyVelocity then return end
        
        local currentSpeed = activeStates.flySpeed
        local cameraCFrame = workspace.CurrentCamera.CFrame
        
        local forward = cameraCFrame.LookVector * Vector3.new(1, 0, 1)
        local right = cameraCFrame.RightVector * Vector3.new(1, 0, 1)
        forward = forward.Unit
        right = right.Unit
        
        local horizontalMove = Vector3.new()
        local verticalMove = 0
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then horizontalMove = horizontalMove + forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then horizontalMove = horizontalMove - forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then horizontalMove = horizontalMove - right end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then horizontalMove = horizontalMove + right end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then verticalMove = 1 end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then verticalMove = -1 end
        
        horizontalMove = horizontalMove + moveDirection
        
        if horizontalMove.Magnitude > 0 then
            horizontalMove = horizontalMove.Unit * currentSpeed
        end
        
        if bodyVelocity then
            bodyVelocity.Velocity = Vector3.new(horizontalMove.X, 0, horizontalMove.Z)
        end
        if verticalVelocity then
            verticalVelocity.Velocity = Vector3.new(0, verticalMove * currentSpeed, 0)
        end
        if bodyGyro and rootPart then
            bodyGyro.CFrame = CFrame.new(rootPart.Position, rootPart.Position + workspace.CurrentCamera.CFrame.LookVector)
        end
    end
    
    flyConnection = RunService.Heartbeat:Connect(updateMovement)
    showNotification(string.format("✈️ Fly Mode ON (Speed: %s)", tostring(speed or 50)), Color3.fromRGB(0, 200, 100))
end

local function stopFly()
    flying = false
    activeStates.fly = false
    
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    if verticalVelocity then verticalVelocity:Destroy() end
    if flyConnection then flyConnection:Disconnect() end
    
    bodyVelocity = nil
    bodyGyro = nil
    verticalVelocity = nil
    flyConnection = nil
    moveDirection = Vector3.new()
    
    if humanoid then
        humanoid.AutoRotate = true
        humanoid.PlatformStand = false
    end
    
    showNotification("🛑 Fly Mode OFF", Color3.fromRGB(200, 50, 50))
end

local function toggleFly(speed)
    if flying then
        stopFly()
    else
        startFly(speed or 50)
    end
end

-- ==================== GODMODE ====================
local godmodeActive = false
local godmodeConnections = {}

local function toggleGodmode()
    godmodeActive = not godmodeActive
    
    if godmodeActive then
        humanoid.BreakJointsOnDeath = false
        
        local healthConn = humanoid:GetPropertyChangedSignal("Health"):Connect(function()
            if godmodeActive and humanoid.Health <= 0 then
                humanoid.Health = humanoid.MaxHealth
            end
        end)
        local diedConn = humanoid.Died:Connect(function()
            if godmodeActive then
                task.wait()
                humanoid.Health = humanoid.MaxHealth
            end
        end)
        
        godmodeConnections = {healthConn, diedConn}
        showNotification("🛡️ GODMODE ACTIVATED", Color3.fromRGB(255, 200, 50))
    else
        for _, conn in ipairs(godmodeConnections) do
            conn:Disconnect()
        end
        godmodeConnections = {}
        humanoid.BreakJointsOnDeath = true
        showNotification("⚠️ GODMODE DEACTIVATED", Color3.fromRGB(255, 100, 50))
    end
end

-- ==================== INVISIBLE ====================
local invisibleActive = false

local function toggleInvisible()
    invisibleActive = not invisibleActive
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = invisibleActive and 1 or 0
        elseif part:IsA("Decal") then
            part.Transparency = invisibleActive and 1 or 0
        end
    end
    
    if invisibleActive then
        showNotification("👻 INVISIBLE ON", Color3.fromRGB(150, 100, 255))
    else
        showNotification("👤 INVISIBLE OFF", Color3.fromRGB(100, 150, 255))
    end
end

