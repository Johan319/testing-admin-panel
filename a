-- Make minimized bar draggable
local minimizedBarDragging = false
local minimizedBarDragInput
local minimizedBarDragStart
local minimizedBarStartPos

minimizedBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        
        if input.Target and input.Target:IsDescendantOf(restoreBtn) then
            return
        end
        
        minimizedBarDragging = true
        minimizedBarDragStart = input.Position
        minimizedBarStartPos = minimizedBar.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                minimizedBarDragging = false
                savedData.minimizedBarX = minimizedBar.Position.X.Offset
                savedData.minimizedBarY = minimizedBar.Position.Y.Offset
                savedData.minimizedBarScale = minimizedBar.Position.X.Scale
                savePosition()
            end
        end)
    end
end)

