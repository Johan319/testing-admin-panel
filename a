    notif.TextSize = 13
    notif.Parent = playerGui
    Instance.new("UICorner", notif).CornerRadius = UDim.new(0, 12)
    Instance.new("UIStroke", notif).Color = color or Color3.fromRGB(80, 150, 255)
    
