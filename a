-- ====================== STABLE FLY SYSTEM (Original) ======================
local function startFly(speed)
    -- (Your full original stable fly code - unchanged)
    if not character or not rootPart then return end
    flying = true
    activeStates.fly = true
    activeStates.flySpeed = speed or 50

    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1, 0, 1) * 100000
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart

    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart

    verticalVelocity = Instance.new("BodyVelocity")
    verticalVelocity.MaxForce = Vector3.new(0, 100000, 0)
    verticalVelocity.Velocity = Vector3.new(0, 0, 0)
    verticalVelocity.Parent = rootPart

    if humanoid then
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
    end

    local function updateMovement()
        if not flying then return end
        local camera = Workspace.CurrentCamera
        local forward = camera.CFrame.LookVector * Vector3.new(1, 0, 1)
        local right = camera.CFrame.RightVector * Vector3.new(1, 0, 1)
        forward = forward.Unit
        right = right.Unit

        local horizontalMove = Vector3.new()
        local verticalMove = 0

        if UserInputService:IsKeyDown(Enum.KeyCode.W) then horizontalMove += forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then horizontalMove -= forward end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then horizontalMove -= right end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then horizontalMove += right end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then verticalMove += 1 end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then verticalMove -= 1 end

        if horizontalMove.Magnitude > 0 then
            horizontalMove = horizontalMove.Unit * activeStates.flySpeed
        end

        if bodyVelocity then bodyVelocity.Velocity = Vector3.new(horizontalMove.X, 0, horizontalMove.Z) end
        if verticalVelocity then verticalVelocity.Velocity = Vector3.new(0, verticalMove * activeStates.flySpeed, 0) end

        if bodyGyro and rootPart then
            local targetCF = CFrame.new(rootPart.Position, rootPart.Position + camera.CFrame.LookVector)
            bodyGyro.CFrame = targetCF
        end
    end

    flyConnection = RunService.Heartbeat:Connect(updateMovement)
end

local function stopFly()
    flying = false
    activeStates.fly = false
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    if verticalVelocity then verticalVelocity:Destroy() end
    if flyConnection then flyConnection:Disconnect() end
    if humanoid then
        humanoid.AutoRotate = true
        humanoid.PlatformStand = false
    end
end

local function enableFly(speed)
    if flying then
        stopFly()
        showNotification("🛑 Fly Mode: OFF", Color3.fromRGB(200, 50, 50))
    else
        startFly(speed or 50)
        showNotification("✈️ Fly Mode: ON (Speed: "..(speed or 50)..")", Color3.fromRGB(0, 200, 100))
    end
end

-- INVISIBLE
local function setInvisible(state)
    activeStates.invisible = state
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") or part:IsA("Decal") then
            part.Transparency = state and 1 or 0
        end
    end
    showNotification(state and "👻 Invisible: ON" or "👤 Invisible: OFF", Color3.fromRGB(150, 100, 255))
end

-- GODMODE
local function enableGodmode()
    activeStates.godmode = not activeStates.godmode
    if activeStates.godmode then
        humanoid.BreakJointsOnDeath = false
        showNotification("🛡️ Godmode: ACTIVATED", Color3.fromRGB(255, 200, 50))
    else
        humanoid.BreakJointsOnDeath = true
        showNotification("⚠️ Godmode: DEACTIVATED", Color3.fromRGB(255, 100, 50))
    end
end

