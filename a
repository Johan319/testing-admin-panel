    if input.UserInputType == Enum.UserInputType.MouseMovement or 
       input.UserInputType == Enum.UserInputType.Touch then
        minimizedBarDragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == minimizedBarDragInput and minimizedBarDragging then
        local delta = input.Position - minimizedBarDragStart
        local newX = minimizedBarStartPos.X.Offset + delta.X
        local newY = minimizedBarStartPos.Y.Offset + delta.Y
        local newScale = minimizedBarStartPos.X.Scale
        
        minimizedBar.Position = UDim2.new(newScale, newX, minimizedBarStartPos.Y.Scale, newY)
        savedData.minimizedBarX = newX
        savedData.minimizedBarY = newY
        savedData.minimizedBarScale = newScale
    end
end)

