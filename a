-- DRAG FUNCTIONALITY FOR MAIN PANEL
local dragging = false
local dragInput
local dragStart
local startPos

local function updateInput(input)
    if dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale, 
            startPos.X.Offset + delta.X, 
            startPos.Y.Scale, 
            startPos.Y.Offset + delta.Y
        )
    end
end

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = main.Position
        
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

titleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or 
       input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        updateInput(input)
    end
end)

-- ====================== ESP SYSTEM ======================

local function createESP(targetPlayer)
    -- Clear existing ESP
    for _, line in pairs(espLines) do
        line:Destroy()
    end
    for _, billboard in pairs(espBillboards) do
        billboard:Destroy()
    end
    for _, conn in pairs(espConnections) do
        conn:Disconnect()
    end
    espLines = {}
    espBillboards = {}
    espConnections = {}
    
    if not targetPlayer or not targetPlayer.Character then
        return false
    end
    
    local targetChar = targetPlayer.Character
    if not targetChar or not targetChar:FindFirstChild("HumanoidRootPart") then
        return false
    end
    
    -- Create a line from player to target
    local line = Instance.new("Part")
    line.Name = "ESP_Line"
    line.Size = Vector3.new(0.1, 0.1, 1)
    line.BrickColor = BrickColor.new("Bright red")
    line.Material = Enum.Material.Neon
    line.Anchored = true
    line.CanCollide = false
    line.Parent = Workspace
    
    -- Outline effect on target
    local outline = Instance.new("SelectionBox")
    outline.Adornee = targetChar
    outline.Color3 = Color3.fromRGB(255, 50, 50)
    outline.LineThickness = 0.1
    outline.Transparency = 0.3
    outline.Parent = targetChar
    
    -- Billboard GUI for player name and info
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "ESP_Billboard"
    billboard.Size = UDim2.new(0, 200, 0, 50)
    billboard.Adornee = targetChar:FindFirstChild("Head") or targetChar:FindFirstChild("HumanoidRootPart")
    billboard.StudsOffset = Vector3.new(0, 2, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = targetChar
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.6, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = targetPlayer.Name
    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    nameLabel.TextScaled = true
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.Parent = billboard
    
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Size = UDim2.new(1, 0, 0.4, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.6, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.TextColor3 = Color3.fromRGB(100, 255, 100)
    healthLabel.TextScaled = true
    healthLabel.Font = Enum.Font.Gotham
    healthLabel.Parent = billboard
    
    local function updateESP()
        if not targetPlayer or not targetPlayer.Character or not targetChar.Parent then
            return
        end
        
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        local myRoot = character:FindFirstChild("HumanoidRootPart")
        
        if targetRoot and myRoot then
            -- Update line
            local myPos = myRoot.Position
            local targetPos = targetRoot.Position
            local direction = (targetPos - myPos)
            local distance = direction.Magnitude
            direction = direction.Unit
            
            line.Size = Vector3.new(0.1, 0.1, distance)
            line.CFrame = CFrame.new(myPos + direction * (distance / 2), targetPos)
            
            -- Update health
            local targetHumanoid = targetChar:FindFirstChild("Humanoid")
            if targetHumanoid then
                local healthPercent = (targetHumanoid.Health / targetHumanoid.MaxHealth) * 100
                healthLabel.Text = string.format("❤️ %.0f%%", healthPercent)
                healthLabel.TextColor3 = healthPercent > 50 and Color3.fromRGB(100, 255, 100) or 
                                         (healthPercent > 20 and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(255, 50, 50))
            end
        end
    end
    
    -- Update line every frame
    local conn = RunService.Heartbeat:Connect(updateESP)
    table.insert(espConnections, conn)
    
    -- Store references
    table.insert(espLines, line)
    table.insert(espBillboards, billboard)
    
    -- Handle character removal
    local removalConn = targetChar.AncestryChanged:Connect(function()
        if not targetChar.Parent then
            removalConn:Disconnect()
            disableESP()
        end
    end)
    table.insert(espConnections, removalConn)
    
    return true
end

local function disableESP()
    for _, line in pairs(espLines) do
        line:Destroy()
    end
    for _, billboard in pairs(espBillboards) do
        billboard:Destroy()
    end
    for _, conn in pairs(espConnections) do
        conn:Disconnect()
    end
    espLines = {}
    espBillboards = {}
    espConnections = {}
    espEnabled = false
    targetedPlayer = nil
end

local function enableESPonPlayer(targetPlayerName)
    if espEnabled then
        disableESP()
    end
    
    local target = Players:FindFirstChild(targetPlayerName)
    if not target then
        showNotification("❌ Player not found: " .. targetPlayerName, Color3.fromRGB(255, 50, 50))
        return false
    end
    
    if target == player then
        showNotification("⚠️ You cannot ESP on yourself!", Color3.fromRGB(255, 200, 0))
        return false
    end
    
    targetedPlayer = target
    local success = createESP(target)
    
    if success then
        espEnabled = true
        showNotification("🔴 ESP ACTIVE on: " .. target.Name, Color3.fromRGB(255, 50, 50))
        return true
    else
        showNotification("❌ Failed to create ESP! Target has no character.", Color3.fromRGB(255, 50, 50))
        return false
    end
end

-- ====================== SPECTATE SYSTEM ======================

local function startSpectate(targetPlayer)
    if not targetPlayer or not targetPlayer.Character then
        showNotification("❌ Cannot spectate: No character found!", Color3.fromRGB(255, 50, 50))
        return false
    end
    
    -- Stop current spectate if any
    if spectating then
        stopSpectate()
    end
    
    -- Save original camera state
    originalCameraCFrame = Camera.CFrame
    originalCameraSubject = Camera.CameraSubject
    
    spectatingTarget = targetPlayer
    spectating = true
    
    -- Set camera to follow target
    local function updateSpectate()
        if spectating and spectatingTarget and spectatingTarget.Character then
            local targetRoot = spectatingTarget.Character:FindFirstChild("HumanoidRootPart")
            if targetRoot then
                Camera.CameraSubject = targetRoot
                Camera.CameraType = Enum.CameraType.Scriptable
                -- Smooth follow
                Camera.CFrame = CFrame.new(targetRoot.Position + Vector3.new(0, 3, 8), targetRoot.Position)
            end
        elseif spectating then
            stopSpectate()
            showNotification("⚠️ Spectated player left the game!", Color3.fromRGB(255, 200, 0))
        end
    end
    
    local spectateConn = RunService.RenderStepped:Connect(updateSpectate)
    table.insert(espConnections, spectateConn)
    
    showNotification("👁️ Spectating: " .. targetPlayer.Name .. " (Press F2 to stop)", Color3.fromRGB(100, 200, 255))
    return true
end

local function stopSpectate()
    if spectating then
        spectating = false
        spectatingTarget = nil
        
        -- Restore normal camera
        Camera.CameraSubject = player.Character and player.Character:FindFirstChild("Humanoid") or nil
        Camera.CameraType = Enum.CameraType.Custom
        
        showNotification("👁️ Spectate mode OFF", Color3.fromRGB(200, 100, 100))
    end
end

-- ====================== STABLE FLY SYSTEM ======================
local function startFly(speed)
    if not character or not rootPart then return end
    
    flying = true
    activeStates.fly = true
    activeStates.flySpeed = speed or 50
    
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(1, 0, 1) * 100000
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = rootPart
    
    bodyGyro = Instance.new("BodyGyro")
    bodyGyro.MaxTorque = Vector3.new(400000, 400000, 400000)
    bodyGyro.CFrame = rootPart.CFrame
    bodyGyro.Parent = rootPart
    
    if humanoid then
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
    end
    
    local moveDirection = Vector3.new()
    
    verticalVelocity = Instance.new("BodyVelocity")
    verticalVelocity.MaxForce = Vector3.new(0, 100000, 0)
    verticalVelocity.Velocity = Vector3.new(0, 0, 0)
    verticalVelocity.Parent = rootPart
    
    local function updateMovement()
        if not flying or not bodyVelocity then return end
        
        local currentSpeed = activeStates.flySpeed
        local cameraCFrame = Camera.CFrame
        
        local forward = cameraCFrame.LookVector * Vector3.new(1, 0, 1)
        local right = cameraCFrame.RightVector * Vector3.new(1, 0, 1)
        
        forward = forward.Unit
        right = right.Unit
        
        local horizontalMove = Vector3.new()
        local verticalMove = 0
        
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then
            horizontalMove = horizontalMove + forward
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then
            horizontalMove = horizontalMove - forward
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then
            horizontalMove = horizontalMove - right
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then
            horizontalMove = horizontalMove + right
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
            verticalMove = verticalMove + 1
        end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
            verticalMove = verticalMove - 1
        end
        
        horizontalMove = horizontalMove + moveDirection
        
        if horizontalMove.Magnitude > 0 then
            horizontalMove = horizontalMove.Unit * currentSpeed
        end
        
        if bodyVelocity then
            bodyVelocity.Velocity = Vector3.new(horizontalMove.X, 0, horizontalMove.Z)
        end
        
        if verticalVelocity then
            verticalVelocity.Velocity = Vector3.new(0, verticalMove * currentSpeed, 0)
        end
        
        if bodyGyro and rootPart then
            local currentCF = rootPart.CFrame
            local targetCF = CFrame.new(currentCF.Position, currentCF.Position + cameraCFrame.LookVector)
            bodyGyro.CFrame = targetCF
        end
    end
    
    local function handleMobileAction(actionName, inputState, inputObject)
        if not flying then return Enum.ContextActionResult.Pass end
        
        local cameraCFrame = Camera.CFrame
        local forward = cameraCFrame.LookVector * Vector3.new(1, 0, 1)
        local right = cameraCFrame.RightVector * Vector3.new(1, 0, 1)
        
        forward = forward.Unit
        right = right.Unit
        
        if actionName == "FlyForward" then
            if inputState == Enum.UserInputState.Begin then
                moveDirection = moveDirection + forward
            elseif inputState == Enum.UserInputState.End then
                moveDirection = moveDirection - forward
            end
        elseif actionName == "FlyBack" then
            if inputState == Enum.UserInputState.Begin then
                moveDirection = moveDirection - forward
            elseif inputState == Enum.UserInputState.End then
                moveDirection = moveDirection + forward
            end
        elseif actionName == "FlyLeft" then
            if inputState == Enum.UserInputState.Begin then
                moveDirection = moveDirection - right
            elseif inputState == Enum.UserInputState.End then
                moveDirection = moveDirection + right
            end
        elseif actionName == "FlyRight" then
            if inputState == Enum.UserInputState.Begin then
                moveDirection = moveDirection + right
            elseif inputState == Enum.UserInputState.End then
                moveDirection = moveDirection - right
            end
        elseif actionName == "FlyUp" then
            if inputState == Enum.UserInputState.Begin then
                if verticalVelocity then
                    verticalVelocity.Velocity = Vector3.new(0, activeStates.flySpeed, 0)
                end
            elseif inputState == Enum.UserInputState.End then
                if verticalVelocity then
                    verticalVelocity.Velocity = Vector3.new(0, 0, 0)
                end
            end
        elseif actionName == "FlyDown" then
            if inputState == Enum.UserInputState.Begin then
                if verticalVelocity then
                    verticalVelocity.Velocity = Vector3.new(0, -activeStates.flySpeed, 0)
                end
            elseif inputState == Enum.UserInputState.End then
                if verticalVelocity then
                    verticalVelocity.Velocity = Vector3.new(0, 0, 0)
                end
            end
        end
        
        return Enum.ContextActionResult.Sink
    end
    
    ContextActionService:BindActionAtPriority("FlyForward", handleMobileAction, false, 1, Enum.KeyCode.Thumbstick1, Enum.UserInputType.Touch)
    ContextActionService:BindActionAtPriority("FlyBack", handleMobileAction, false, 1, Enum.KeyCode.Thumbstick2, Enum.UserInputType.Touch)
    ContextActionService:BindActionAtPriority("FlyLeft", handleMobileAction, false, 1, Enum.KeyCode.Thumbstick3, Enum.UserInputType.Touch)
    ContextActionService:BindActionAtPriority("FlyRight", handleMobileAction, false, 1, Enum.KeyCode.Thumbstick4, Enum.UserInputType.Touch)
    ContextActionService:BindActionAtPriority("FlyUp", handleMobileAction, false, 1, Enum.KeyCode.ButtonR1, Enum.UserInputType.Touch)
    ContextActionService:BindActionAtPriority("FlyDown", handleMobileAction, false, 1, Enum.KeyCode.ButtonL1, Enum.UserInputType.Touch)
    
    flyConnection = RunService.Heartbeat:Connect(updateMovement)
end

local function stopFly()
    flying = false
    activeStates.fly = false
    
    if bodyVelocity then bodyVelocity:Destroy() end
    if bodyGyro then bodyGyro:Destroy() end
    if verticalVelocity then verticalVelocity:Destroy() end
    if flyConnection then flyConnection:Disconnect() end
    
    bodyVelocity = nil
    bodyGyro = nil
    verticalVelocity = nil
    flyConnection = nil
    currentMoveVector = Vector3.new()
    
    if humanoid then
        humanoid.AutoRotate = true
        humanoid.PlatformStand = false
    end
    
    ContextActionService:UnbindAction("FlyForward")
    ContextActionService:UnbindAction("FlyBack")
    ContextActionService:UnbindAction("FlyLeft")
    ContextActionService:UnbindAction("FlyRight")
    ContextActionService:UnbindAction("FlyUp")
    ContextActionService:UnbindAction("FlyDown")
end

local function enableFly(speed)
    if flying then
        stopFly()
        showNotification("🛑 Fly Mode: OFF", Color3.fromRGB(200, 50, 50))
    else
        startFly(speed or 50)
        showNotification(string.format("✈️ Fly Mode: ON (Speed: %s)", tostring(speed or 50)), Color3.fromRGB(0, 200, 100))
    end
end

-- ====================== INVISIBLE FUNCTION ======================
local function setInvisible(state)
    activeStates.invisible = state
    
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = state and 1 or 0
        elseif part:IsA("Decal") then
            part.Transparency = state and 1 or 0
        end
    end
    
    if state then
        showNotification("👻 Invisible: ON", Color3.fromRGB(150, 100, 255))
    else
        showNotification("👤 Invisible: OFF", Color3.fromRGB(100, 150, 255))
