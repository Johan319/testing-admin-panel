-- Refresh player list
local function refreshPlayerList(searchText)
    for _, child in ipairs(playerContainer:GetChildren()) do
        if child:IsA("Frame") and child ~= playerLayout then
            child:Destroy()
        end
    end
    
    local searchLower = searchText and searchText:lower() or ""
    local playersList = Players:GetPlayers()
    local count = 0
    
    for _, plr in ipairs(playersList) do
        if searchLower == "" or plr.Name:lower():find(searchLower) then
            createPlayerRow(plr)
            count = count + 1
        end
    end
    
    playerContainer.CanvasSize = UDim2.new(0, 0, 0, count * 64 + 10)
    statsLabel.Text = "👥 " .. #playersList .. " players online"
end

-- Search functionality
searchBox:GetPropertyChangedSignal("Text"):Connect(function()
    refreshPlayerList(searchBox.Text)
end)

-- Live updates
Players.PlayerAdded:Connect(function() refreshPlayerList(searchBox.Text) end)
Players.PlayerRemoving:Connect(function() refreshPlayerList(searchBox.Text) end)

-- Character respawn handler
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    rootPart = character:WaitForChild("HumanoidRootPart")
    humanoid = character:WaitForChild("Humanoid")
    
    task.wait(0.5)
    if godmodeActive then toggleGodmode() end
    if invisibleActive then toggleInvisible() end
end)

-- ==================== DRAG SYSTEM ====================
local dragging = false
local dragStart, startPos

header.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

