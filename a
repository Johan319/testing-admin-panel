UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.F3 then
        getNumberInput("Set Walk Speed:", 16, 16, 500, "Speed", function(speed)
            humanoid.WalkSpeed = speed
            activeStates.walkspeed = speed
            showNotification(string.format("🏃 Walk Speed: %s", speed), Color3.fromRGB(100, 200, 255))
        end)
    elseif input.KeyCode == Enum.KeyCode.F4 then
        getNumberInput("Set Jump Power:", 50, 50, 500, "Power", function(power)
            humanoid.JumpPower = power
            activeStates.jumppower = power
            showNotification(string.format("🦘 Jump Power: %s", power), Color3.fromRGB(255, 150, 100))
        end)
    elseif input.KeyCode == Enum.KeyCode.F5 then
        toggleFly()
    elseif input.KeyCode == Enum.KeyCode.F6 then
        toggleGodmode()
    elseif input.KeyCode == Enum.KeyCode.F7 then
        toggleInvisible()
    elseif input.KeyCode == Enum.KeyCode.F8 then
        toggleESP()
    end
end)

