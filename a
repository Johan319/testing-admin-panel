UserInputService.InputBegan:Connect(function(input, gp)
    if gp then return end
    if input.KeyCode == Enum.KeyCode.F2 then
        main.Visible = not main.Visible
        if main.Visible and minimizedBar.Visible then minimizedBar.Visible = false end
        if main.Visible then switchPage("Home") end
    end
end)

-- Mobile Tap
local openDetector = Instance.new("TextButton")
openDetector.Size = UDim2.new(0, 70, 0, 50)
openDetector.Position = UDim2.new(0, 0, 0, 0)
openDetector.BackgroundTransparency = 1
openDetector.Text = ""
openDetector.Parent = screenGui

openDetector.MouseButton1Click:Connect(function()
    main.Visible = not main.Visible
    if main.Visible then switchPage("Home") end
end)

